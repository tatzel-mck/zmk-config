#include <dt-bindings/zmk/matrix_transform.h>

#include "totem_handwired-layouts.dtsi"

/ {
    chosen {
        zmk,physical-layout = &default_layout;
    };

    kscan: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        // DÜZELTİLDİ: Fiziksel diyot yönüne (Katot -> Row) göre akım yönü row2col yapıldı.
        diode-direction = "row2col";
        wakeup-source;

        // Row (Satır) Pinleri: D0, D1, D2, D3
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

        // Col (Sütun) Pinleri: D4, D5, D6, D7, D8, D9
        col-gpios
            = <&xiao_d 4 GPIO_ACTIVE_HIGH>
            , <&xiao_d 5 GPIO_ACTIVE_HIGH>
            , <&xiao_d 6 GPIO_ACTIVE_HIGH>
            , <&xiao_d 7 GPIO_ACTIVE_HIGH>
            , <&xiao_d 8 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH>
            ;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <12>; // Toplam sütun sayısı (Sol 6 + Sağ 6)
        rows = <4>;    // Toplam satır sayısı

        // Senin verdiğin Gallium v2 uyumlu 38 tuş matris haritası
        map = <
    RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)             RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
    RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
    RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)             RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
    RC(3,0) RC(3,1) RC(3,2)                             RC(3,6) RC(3,7) RC(3,8)
>;
    };
};