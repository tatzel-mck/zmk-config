#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>; // 6 columns per side
        rows = <4>;
        
        // Maps the matrix (Row, Col) to the physical keys on the board
        map = <
                    RC(0,4) RC(0,3) RC(0,2) RC(0,1) RC(0,0)         RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,5) RC(1,4) RC(1,3) RC(1,2) RC(1,1) RC(1,0)         RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
                    RC(2,4) RC(2,3) RC(2,2) RC(2,1) RC(2,0)         RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
                                    RC(3,2) RC(3,1) RC(3,0)         RC(3,6) RC(3,7) RC(3,8)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        
        // Diode cathode (black line) facing the row wire
        diode-direction = "col2row";

        // Columns: Driven HIGH sequentially
        col-gpios
            = <&xiao_d 4 GPIO_ACTIVE_HIGH> // Col 0 (Inner Index)
            , <&xiao_d 5 GPIO_ACTIVE_HIGH> // Col 1 (Index)
            , <&xiao_d 6 GPIO_ACTIVE_HIGH> // Col 2 (Middle)
            , <&xiao_d 7 GPIO_ACTIVE_HIGH> // Col 3 (Ring)
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> // Col 4 (Pinky)
            , <&xiao_d 9 GPIO_ACTIVE_HIGH> // Col 5 (Outer Pinky)
            ;

        // Rows: Sensed, requires Pull-Down resistors for col2row
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 0 (Top)
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 1 (Home)
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 2 (Bottom)
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 3 (Thumb cluster)
            ;
    };
};